# Biglybigly Configuration

# Server mode: server or agent
BIGLYBIGLY_MODE=server

# HTTP server address
BIGLYBIGLY_HTTP_ADDR=:8082

# Base URL for OAuth redirects and links (change for production)
BIGLYBIGLY_BASE_URL=http://localhost:8082

# Database file path (in Docker, use /data)
BIGLYBIGLY_DB_PATH=/data/biglybigly.db

# Session TTL in seconds (default: 30 days)
# BIGLYBIGLY_SESSION_TTL=2592000

# Google OAuth (optional)
# BIGLYBIGLY_GOOGLE_CLIENT_ID=your_client_id
# BIGLYBIGLY_GOOGLE_CLIENT_SECRET=your_client_secret

# GitHub OAuth (optional)
# BIGLYBIGLY_GITHUB_CLIENT_ID=your_client_id
# BIGLYBIGLY_GITHUB_CLIENT_SECRET=your_client_secret

# Agent mode settings (only when BIGLYBIGLY_MODE=agent)
# BIGLYBIGLY_SERVER_URL=https://example.com
# BIGLYBIGLY_AGENT_TOKEN=pre-shared-token-from-server

# Module-specific config (example for DNS module if present)
# BIGLYBIGLY_DNS_LISTEN=:53
# BIGLYBIGLY_DNS_BLOCKLISTS=https://example.com/blocklist.txt
